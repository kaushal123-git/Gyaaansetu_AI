# GyaanSetu AI Backend — Environment Variables
# Copy this file to .env and fill in your values

# ── Ollama ───────────────────────────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3.1:8b
OLLAMA_CODE_MODEL=deepseek-r1
OLLAMA_FAST_MODEL=phi3
OLLAMA_CREATIVE_MODEL=gemma3

# ── Whisper ──────────────────────────────────────────────────────────────────
# Options: tiny, base, small, medium, large-v3
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
# Set to "cuda" if you have an NVIDIA GPU: WHISPER_DEVICE=cuda

# ── Piper TTS ────────────────────────────────────────────────────────────────
# Path to piper executable (download from https://github.com/rhasspy/piper)
PIPER_EXECUTABLE=piper
PIPER_MODELS_DIR=./piper_models
PIPER_DEFAULT_VOICE=en_US-lessac-medium
PIPER_HINDI_VOICE=hi_IN-sangita-medium

# ── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMADB_PATH=./chroma_store

# ── SQLite ───────────────────────────────────────────────────────────────────
SQLITE_DB_PATH=./gyaansetu_ai.db

# ── Server ───────────────────────────────────────────────────────────────────
HOST=0.0.0.0
PORT=8000
